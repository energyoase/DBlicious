#!/bin/sh
#
# DBlicious pre-push — clippy als CI-Readiness-Gate vor dem Push.
# Schwerer als fmt (voller Build), darum hier statt im pre-commit-Hook.
#
# Hintergrund: docs/queue/done/Q0010. --all-targets lintet auch Test-Code;
# die dort frueher vorhandenen pre-existing Test-Lints wurden bereinigt
# (2026-05-25), daher ist --all-targets jetzt der verifiziert-gruene Stand.

set -eu

echo "pre-push: cargo clippy --workspace --all-targets -- -D warnings ..." >&2
if ! cargo clippy --workspace --all-targets -- -D warnings; then
    echo "" >&2
    echo "X pre-push: clippy-Warnings (siehe oben)." >&2
    echo "  Fix die Lints, oder Notfall-Umgehung:  git push --no-verify" >&2
    echo "" >&2
    exit 1
fi

exit 0
